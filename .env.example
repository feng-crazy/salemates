# =============================================================================
# SaleMates AI Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# Config prefix: NANOBOT_ (e.g., NANOBOT_AGENTS__MODEL)

# -----------------------------------------------------------------------------
# LLM Provider API Keys (choose one or more)
# -----------------------------------------------------------------------------
# OpenAI
NANOBOT_OPENAI_API_KEY=sk-...

# Anthropic Claude
NANOBOT_ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (aggregator)
NANOBOT_OPENROUTER_API_KEY=sk-or-...

# Chinese providers
NANOBOT_DASHSCOPE_API_KEY=sk-...      # Alibaba Qwen
NANOBOT_DEEPSEEK_API_KEY=sk-...        # DeepSeek
NANOBOT_ZHIPUAI_API_KEY=...            # Zhipu AI (智谱)
NANOBOT_MOONSHOT_API_KEY=sk-...        # Moonshot (月之暗面)
NANOBOT_VOLC_API_KEY=...               # Volcengine (火山引擎)

# Other providers
NANOBOT_GEMINI_API_KEY=...             # Google Gemini
NANOBOT_GROQ_API_KEY=gsk_...           # Groq (fast inference)
NANOBOT_MINIMAX_API_KEY=...            # MiniMax

# -----------------------------------------------------------------------------
# OpenViking Configuration
# -----------------------------------------------------------------------------
NANOBOT_OV_SERVER__MODE=remote
NANOBOT_OV_SERVER__URL=http://localhost:1933

# -----------------------------------------------------------------------------
# Channel: Feishu (飞书)
# -----------------------------------------------------------------------------
NANOBOT_CHANNELS__FEISHU__APP_ID=cli_...
NANOBOT_CHANNELS__FEISHU__APP_SECRET=...
NANOBOT_CHANNELS__FEISHU__VERIFICATION_TOKEN=...
NANOBOT_CHANNELS__FEISHU__ENCRYPT_KEY=...

# -----------------------------------------------------------------------------
# Channel: Telegram
# -----------------------------------------------------------------------------
NANOBOT_CHANNELS__TELEGRAM__BOT_TOKEN=...

# -----------------------------------------------------------------------------
# Channel: WhatsApp (via Bridge)
# -----------------------------------------------------------------------------
NANOBOT_CHANNELS__WHATSAPP__BRIDGE_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Channel: Discord
# -----------------------------------------------------------------------------
NANOBOT_CHANNELS__DISCORD__BOT_TOKEN=...

# -----------------------------------------------------------------------------
# Channel: Slack
# -----------------------------------------------------------------------------
NANOBOT_CHANNELS__SLACK__BOT_TOKEN=xoxb-...
NANOBOT_CHANNELS__SLACK__APP_TOKEN=xapp-...

# -----------------------------------------------------------------------------
# Channel: DingTalk (钉钉)
# -----------------------------------------------------------------------------
NANOBOT_CHANNELS__DINGTALK__APP_KEY=...
NANOBOT_CHANNELS__DINGTALK__APP_SECRET=...

# -----------------------------------------------------------------------------
# Channel: Email
# -----------------------------------------------------------------------------
NANOBOT_CHANNELS__EMAIL__SMTP_HOST=smtp.gmail.com
NANOBOT_CHANNELS__EMAIL__SMTP_PORT=587
NANOBOT_CHANNELS__EMAIL__SMTP_USER=your-email@gmail.com
NANOBOT_CHANNELS__EMAIL__SMTP_PASSWORD=...

# -----------------------------------------------------------------------------
# Channel: OpenAPI
# -----------------------------------------------------------------------------
NANOBOT_CHANNELS__OPENAPI__API_KEY=...

# -----------------------------------------------------------------------------
# Human Handoff (Feishu Group)
# -----------------------------------------------------------------------------
NANOBOT_SAFETY__HUMAN_HANDOFF__GROUP_ID=oc_...

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# PostgreSQL (persistent storage)
DATABASE_URL=postgresql://user:password@localhost:5432/salemates

# Redis (session cache)
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Observability (Optional)
# -----------------------------------------------------------------------------
NANOBOT_LANGFUSE__PUBLIC_KEY=pk-...
NANOBOT_LANGFUSE__SECRET_KEY=sk-...
NANOBOT_LANGFUSE__HOST=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# Gateway Server
# -----------------------------------------------------------------------------
NANOBOT_GATEWAY__HOST=0.0.0.0
NANOBOT_GATEWAY__PORT=18790

# -----------------------------------------------------------------------------
# Agent Configuration
# -----------------------------------------------------------------------------
NANOBOT_AGENTS__MODEL=gpt-4o
NANOBOT_AGENTS__MAX_TOOL_ITERATIONS=10
NANOBOT_AGENTS__MEMORY_WINDOW=20

# -----------------------------------------------------------------------------
# Tools (Optional)
# -----------------------------------------------------------------------------
NANOBOT_TOOLS__WEB_SEARCH__BRAVE_API_KEY=...
NANOBOT_TOOLS__WEB_SEARCH__EXA_API_KEY=...

# -----------------------------------------------------------------------------
# Safety Guardrails
# -----------------------------------------------------------------------------
NANOBOT_SAFETY__PRICE_GUARDRAIL__MAX_DISCOUNT_PERCENT=15.0
NANOBOT_SAFETY__EMOTION_FUSE__ANGER_THRESHOLD=0.7
NANOBOT_SAFETY__EMOTION_FUSE__FRUSTRATION_THRESHOLD=0.7